import discord
from discord.ext import commands, tasks
import sqlite3
from datetime import datetime
import os

# ===== Webサーバー（常時稼働用）=====
from flask import Flask
import threading

app = Flask('')

@app.route('/')
def home():
    return "alive"

def run():
    app.run(host='0.0.0.0', port=8080)

def keep_alive():
    t = threading.Thread(target=run)
    t.start()

# ===== 設定（Renderで環境変数にする）=====
TOKEN = os.environ["TOKEN"]
ADMIN_ROLE_ID = int(os.environ["ADMIN_ROLE_ID"])
MAIN_CHANNEL_ID = int(os.environ["MAIN_CHANNEL_ID"])
LOG_CHANNEL_ID = int(os.environ["LOG_CHANNEL_ID"])

# ===== DB =====
conn = sqlite3.connect("vacation.db")
c = conn.cursor()

c.execute("""
CREATE TABLE IF NOT EXISTS requests (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER,
    period TEXT,
    reason TEXT,
    comment TEXT,
    status TEXT,
    end_date TEXT
)
""")
conn.commit()

# ===== Bot =====
intents = discord.Intents.default()
intents.message_content = True

bot = commands.Bot(command_prefix="!", intents=intents)

# ===== 日付処理 =====
def parse_end_date(period):
    try:
        end = period.split("-")[-1]
        return datetime.strptime(end.strip(), "%m/%d")
    except:
        return None

# ===== 一覧更新 =====
async def update_status():
    channel = bot.get_channel(MAIN_CHANNEL_ID)

    c.execute("SELECT user_id, period FROM requests WHERE status='承認'")
    rows = c.fetchall()

    text = "📌【休暇中一覧】\n\n"
    if rows:
        for r in rows:
            text += f"<@{r[0]}> ： {r[1]}\n"
    else:
        text += "なし"

    async for msg in channel.history(limit=20):
        if msg.author == bot.user and "休暇中一覧" in msg.content:
            await msg.delete()

    await channel.send(text)

# ===== 自動終了チェック =====
@tasks.loop(minutes=1)
async def check_end():
    now = datetime.now()

    c.execute("SELECT id, user_id, end_date FROM requests WHERE status='承認'")
    rows = c.fetchall()

    channel = bot.get_channel(MAIN_CHANNEL_ID)

    for r in rows:
        if r[2]:
            end = datetime.strptime(r[2], "%m/%d").replace(hour=23, minute=59)

            if now > end:
                c.execute("UPDATE requests SET status='終了' WHERE id=?", (r[0],))
                conn.commit()

                user = await bot.fetch_user(r[1])
                try:
                    await user.send("⏰ 休暇が終了しました！")
                except:
                    pass

                await channel.send(f"🔔 <@{r[1]}> の休暇が終了しました！")

    await update_status()

# ===== ボタン =====
class VacationView(discord.ui.View):
    def __init__(self):
        super().__init__(timeout=None)

    @discord.ui.button(label="休暇申請", style=discord.ButtonStyle.primary)
    async def apply(self, interaction: discord.Interaction, button: discord.ui.Button):
        await interaction.response.send_modal(VacationModal())

# ===== モーダル =====
class VacationModal(discord.ui.Modal, title="休暇申請"):
    period = discord.ui.TextInput(label="期間 (例: 4/10-4/12)")
    reason = discord.ui.TextInput(label="理由")
    comment = discord.ui.TextInput(label="ひとこと", required=False)

    async def on_submit(self, interaction: discord.Interaction):

        c.execute("SELECT * FROM requests WHERE user_id=? AND status IN ('未処理','承認')",
                  (interaction.user.id,))
        if c.fetchone():
            await interaction.response.send_message("すでに申請中または休暇中です！", ephemeral=True)
            return

        c.execute("INSERT INTO requests (user_id, period, reason, comment, status) VALUES (?, ?, ?, ?, ?)",
                  (interaction.user.id, self.period.value, self.reason.value, self.comment.value, "未処理"))
        conn.commit()

        request_id = c.lastrowid

        embed = discord.Embed(title="休暇申請")
        embed.add_field(name="申請者", value=interaction.user.mention)
        embed.add_field(name="期間", value=self.period.value)
        embed.add_field(name="理由", value=self.reason.value)
        embed.add_field(name="ひとこと", value=self.comment.value)

        view = ApprovalView(request_id)

        channel = bot.get_channel(MAIN_CHANNEL_ID)
        await channel.send(embed=embed, view=view)

        await interaction.response.send_message("申請しました！", ephemeral=True)

# ===== 承認ボタン =====
class ApprovalView(discord.ui.View):
    def __init__(self, request_id):
        super().__init__(timeout=None)
        self.request_id = request_id

    def is_admin(self, interaction):
        return any(role.id == ADMIN_ROLE_ID for role in interaction.user.roles)

    @discord.ui.button(label="承認", style=discord.ButtonStyle.success)
    async def approve(self, interaction: discord.Interaction, button: discord.ui.Button):
        if not self.is_admin(interaction):
            await interaction.response.send_message("権限なし", ephemeral=True)
            return

        c.execute("SELECT period FROM requests WHERE id=?", (self.request_id,))
        period = c.fetchone()[0]
        end_date = parse_end_date(period)

        c.execute("UPDATE requests SET status='承認', end_date=? WHERE id=?",
                  (end_date.strftime("%m/%d") if end_date else None, self.request_id))
        conn.commit()

        await interaction.response.send_message("承認しました！", ephemeral=True)
        await update_status()

    @discord.ui.button(label="却下", style=discord.ButtonStyle.danger)
    async def reject(self, interaction: discord.Interaction, button: discord.ui.Button):
        if not self.is_admin(interaction):
            await interaction.response.send_message("権限なし", ephemeral=True)
            return

        c.execute("UPDATE requests SET status='却下' WHERE id=?", (self.request_id,))
        conn.commit()

        await interaction.response.send_message("却下しました！", ephemeral=True)

# ===== 起動時 =====
@bot.event
async def on_ready():
    print("起動完了")
    check_end.start()

# ===== 実行 =====
keep_alive()
bot.run(TOKEN)